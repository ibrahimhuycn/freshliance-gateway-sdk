{
  "Freshliance": {
    "AppId": "",
    "PrivateKey": "",
    "PublicKey": "",
    "AcceptLanguage": "en-US"
  },
  "Polling": {
    "IntervalSeconds": 30,
    "Enabled": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*"
}
