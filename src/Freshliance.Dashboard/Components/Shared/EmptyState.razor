<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="my-8" data-testid="empty-state">
    <MudIcon Icon="@Icon" Size="Size.Large" Color="Color.Secondary" />
    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">@Message</MudText>
    @if (ActionText is not null)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="Action" Class="mt-2">
            @ActionText
        </MudButton>
    }
</MudStack>

@code {
    [Parameter] public string Icon { get; set; } = @Icons.Material.Filled.Info;
    [Parameter] public string Message { get; set; } = "No data available";
    [Parameter] public string? ActionText { get; set; }
    [Parameter] public EventCallback OnAction { get; set; }

    private async Task Action() => await OnAction.InvokeAsync();
}
